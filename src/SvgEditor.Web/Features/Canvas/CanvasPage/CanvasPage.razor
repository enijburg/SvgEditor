@page "/"
@using Microsoft.JSInterop
@using SvgEditor.Web.Features.Canvas.Models
@using SvgEditor.Web.Features.Canvas.ResizeElement
@using SvgEditor.Web.Features.Canvas.SelectElement
@using SvgEditor.Web.Features.Canvas.UpdateElement
@using SvgEditor.Web.Features.History.PushHistory
@using SvgEditor.Web.Features.History.UndoRedo
@using SvgEditor.Web.Shared.Mediator
@using SvgEditor.Web.Shared.Storage
@implements IAsyncDisposable
@inject IMediator Mediator
@inject EditorState EditorState
@inject IStorageService StorageService
@inject AutoSaveService AutoSaveService
@inject IJSRuntime JSRuntime

<div class="canvas-page">
    <Toolbar />
    <div class="canvas-area">
        @if (EditorState.Document is not null)
        {
            <svg id="canvas-svg"
                 viewBox="@EditorState.Document.ViewBox"
                 width="@(EditorState.Document.Width > 0 ? EditorState.Document.Width.ToString(System.Globalization.CultureInfo.InvariantCulture) : null)"
                 height="@(EditorState.Document.Height > 0 ? EditorState.Document.Height.ToString(System.Globalization.CultureInfo.InvariantCulture) : null)"
                 @ref="_svgRef">
                @foreach (var element in EditorState.Document.Elements)
                {
                    <SvgElementRenderer Element="element" SelectedIds="EditorState.SelectedElementIds" />
                }
                <SelectionDecorator Elements="GetSelectedElements()" />
                @if (_fenceRect is not null)
                {
                    <rect x="@F(_fenceRect.Value.x)"
                          y="@F(_fenceRect.Value.y)"
                          width="@F(_fenceRect.Value.w)"
                          height="@F(_fenceRect.Value.h)"
                          fill="rgba(13,110,253,0.1)"
                          stroke="#0d6efd"
                          stroke-width="1"
                          stroke-dasharray="4,2"
                          pointer-events="none" />
                }
            </svg>
        }
        else
        {
            <div class="empty-state">
                <p>No SVG document loaded.</p>
                <p>Click <strong>Open</strong> to import an SVG file.</p>
            </div>
        }
    </div>
    <SvgEditor.Web.Features.Copilot.CopilotPanel.CopilotPanel />
</div>

@code {
    private ElementReference _svgRef;
    private DotNetObjectReference<CanvasPage>? _dotNetRef;
    private bool _historyPushed;
    private string? _dragElementId;
    private bool _canvasInitialized;
    private bool _isFencing;
    private (double x, double y, double w, double h)? _fenceRect;
    private double _fenceStartX;
    private double _fenceStartY;
    private string? _resizeHandle;
    private BoundingBox? _resizeOriginalBounds;

    protected override async Task OnInitializedAsync()
    {
        EditorState.OnStateChanged += OnEditorStateChanged;

        // Restore from localStorage on startup
        try
        {
            var saved = await StorageService.GetAsync<SvgDocument>(StorageKeys.ActiveDocument);
            if (saved is not null && EditorState.Document is null)
            {
                EditorState.Document = saved;
            }
        }
        catch
        {
            // Ignore storage errors on startup
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_canvasInitialized && EditorState.Document is not null)
        {
            await InitCanvas();
        }
    }

    private async Task InitCanvas()
    {
        if (_canvasInitialized) return;
        _canvasInitialized = true;
        _dotNetRef = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("svgEditorCanvas.initCanvas", _dotNetRef, _svgRef);
    }

    private void OnEditorStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private List<SvgElement> GetSelectedElements()
    {
        if (EditorState.Document is null || EditorState.SelectedElementIds.Count == 0)
            return [];

        var result = new List<SvgElement>();
        foreach (var id in EditorState.SelectedElementIds)
        {
            var el = EditorState.Document.FindById(id);
            if (el is not null)
                result.Add(el);
        }
        return result;
    }

    private static string F(double value) =>
        value.ToString(System.Globalization.CultureInfo.InvariantCulture);

    [JSInvokable]
    public async Task OnElementMouseDown(string elementId, double svgX, double svgY, bool ctrlKey)
    {
        _historyPushed = false;

        await Mediator.Send(new SelectElementCommand(elementId, ctrlKey));

        if (ctrlKey)
        {
            // Ctrl+click: toggle done above, start fencing for potential drag-to-select
            _dragElementId = null;
            _isFencing = true;
            _fenceStartX = svgX;
            _fenceStartY = svgY;
            _fenceRect = (svgX, svgY, 0, 0);
        }
        else
        {
            _isFencing = false;
            _fenceRect = null;

            // If this element is in the selection, enable dragging all selected elements
            if (EditorState.SelectedElementIds.Contains(elementId))
            {
                _dragElementId = elementId;
            }
            else
            {
                _dragElementId = null;
            }
        }
    }

    [JSInvokable]
    public async Task OnCanvasMouseDown(double svgX, double svgY, bool ctrlKey)
    {
        _historyPushed = false;
        _dragElementId = null;

        if (!ctrlKey)
        {
            // Clear selection when clicking on empty canvas without Ctrl
            await Mediator.Send(new SelectElementCommand(null));
        }

        // Start fence selection
        _isFencing = true;
        _fenceStartX = svgX;
        _fenceStartY = svgY;
        _fenceRect = (svgX, svgY, 0, 0);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnMouseMove(double dx, double dy, double svgX, double svgY)
    {
        if (_isFencing)
        {
            var x = Math.Min(_fenceStartX, svgX);
            var y = Math.Min(_fenceStartY, svgY);
            var w = Math.Abs(svgX - _fenceStartX);
            var h = Math.Abs(svgY - _fenceStartY);
            _fenceRect = (x, y, w, h);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_dragElementId is null) return;

        // Push history snapshot once, before the first move
        if (!_historyPushed)
        {
            _historyPushed = true;
            await Mediator.Send(new PushHistoryCommand("Move element"));
        }

        if (EditorState.SelectedElementIds.Count > 1)
        {
            await Mediator.Send(new UpdateMultipleElementsCommand(EditorState.SelectedElementIds, dx, dy));
        }
        else
        {
            await Mediator.Send(new UpdateElementCommand(_dragElementId, dx, dy));
        }
    }

    [JSInvokable]
    public async Task OnMouseUp(double svgX, double svgY)
    {
        // Require minimum 2px fence size to avoid accidental selection from small mouse movements during clicks
        if (_isFencing && _fenceRect is var (x, y, w, h) && (w > 2 || h > 2))
        {
            await Mediator.Send(new FenceSelectCommand(new BoundingBox(x, y, w, h)));
        }

        _historyPushed = false;
        _dragElementId = null;
        _isFencing = false;
        _fenceRect = null;
    }

    [JSInvokable]
    public Task OnResizeHandleMouseDown(string handle, double svgX, double svgY)
    {
        _historyPushed = false;
        _resizeHandle = handle;
        _resizeOriginalBounds = GetSelectionBoundingBox();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnResizeMouseMove(double dx, double dy, double svgX, double svgY)
    {
        if (_resizeHandle is null || _resizeOriginalBounds is null) return;

        if (!_historyPushed)
        {
            _historyPushed = true;
            await Mediator.Send(new PushHistoryCommand("Resize"));
        }

        var ob = _resizeOriginalBounds;
        var newX = ob.X;
        var newY = ob.Y;
        var newW = ob.Width;
        var newH = ob.Height;

        if (_resizeHandle.Contains('e'))
        {
            newW += dx;
        }
        if (_resizeHandle.Contains('w'))
        {
            newX += dx;
            newW -= dx;
        }
        if (_resizeHandle.Contains('s'))
        {
            newH += dy;
        }
        if (_resizeHandle.Contains('n'))
        {
            newY += dy;
            newH -= dy;
        }

        if (newW < 1) newW = 1;
        if (newH < 1) newH = 1;

        var updatedBounds = new BoundingBox(newX, newY, newW, newH);
        _resizeOriginalBounds = updatedBounds;

        await Mediator.Send(new ResizeElementCommand(
            EditorState.SelectedElementIds,
            ob,
            updatedBounds));
    }

    [JSInvokable]
    public Task OnResizeMouseUp()
    {
        _historyPushed = false;
        _resizeHandle = null;
        _resizeOriginalBounds = null;
        return Task.CompletedTask;
    }

    private BoundingBox? GetSelectionBoundingBox()
    {
        var elements = GetSelectedElements();
        if (elements.Count == 0) return null;

        double minX = double.MaxValue, minY = double.MaxValue;
        double maxX = double.MinValue, maxY = double.MinValue;

        foreach (var el in elements)
        {
            var bb = el.GetBoundingBox();
            if (bb is null) continue;
            minX = Math.Min(minX, bb.X);
            minY = Math.Min(minY, bb.Y);
            maxX = Math.Max(maxX, bb.X + bb.Width);
            maxY = Math.Max(maxY, bb.Y + bb.Height);
        }

        return minX > maxX ? null : new BoundingBox(minX, minY, maxX - minX, maxY - minY);
    }

    [JSInvokable]
    public async Task OnKeyDown(string action)
    {
        switch (action)
        {
            case "undo":
                await Mediator.Send(new UndoCommand());
                break;
            case "redo":
                await Mediator.Send(new RedoCommand());
                break;
        }
    }

    public async ValueTask DisposeAsync()
    {
        EditorState.OnStateChanged -= OnEditorStateChanged;
        await JSRuntime.InvokeVoidAsync("svgEditorCanvas.dispose");
        _dotNetRef?.Dispose();
    }
}
