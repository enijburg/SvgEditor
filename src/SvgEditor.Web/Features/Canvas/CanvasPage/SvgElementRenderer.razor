@using SvgEditor.Web.Features.Canvas.Models

@if (Element is SvgGroup group)
{
    <g @attributes="GetAttributes(group)">
        @foreach (var child in group.Children)
        {
            <SvgElementRenderer Element="child" SelectedId="SelectedId" />
        }
    </g>
}
else if (Element is SvgRect)
{
    <rect @attributes="GetAttributes(Element)" />
}
else if (Element is SvgCircle)
{
    <circle @attributes="GetAttributes(Element)" />
}
else if (Element is SvgEllipse)
{
    <ellipse @attributes="GetAttributes(Element)" />
}
else if (Element is SvgLine)
{
    <line @attributes="GetAttributes(Element)" />
}
else if (Element is SvgPolyline)
{
    <polyline @attributes="GetAttributes(Element)" />
}
else if (Element is SvgPolygon)
{
    <polygon @attributes="GetAttributes(Element)" />
}
else if (Element is SvgPath)
{
    <path @attributes="GetAttributes(Element)" />
}
else if (Element is SvgText textEl)
{
    @((MarkupString)RenderSvgText(textEl))
}
else
{
    @* Unknown element — render as a group wrapper so it remains selectable *@
    <g @attributes="GetAttributes(Element)"></g>
}

@code {
    [Parameter, EditorRequired] public SvgElement Element { get; set; } = null!;
    [Parameter] public string? SelectedId { get; set; }

    private Dictionary<string, object> GetAttributes(SvgElement element)
    {
        var result = new Dictionary<string, object>();
        foreach (var (k, v) in element.Attributes)
        {
            if (k == "data-element-id") continue;
            result[k] = v;
        }
        result["data-element-id"] = element.Id;
        if (element.Id == SelectedId)
        {
            var existing = result.TryGetValue("class", out var cls) ? cls + " selected" : "selected";
            result["class"] = existing;
        }
        return result;
    }

    private static MarkupString RenderSvgText(SvgText textEl)
    {
        var attrString = string.Join(" ", textEl.Attributes.Select(kvp =>
            $"{System.Net.WebUtility.HtmlEncode(kvp.Key)}=\"{System.Net.WebUtility.HtmlEncode(kvp.Value)}\""));
        attrString += $" data-element-id=\"{System.Net.WebUtility.HtmlEncode(textEl.Id)}\"";
        var content = System.Net.WebUtility.HtmlEncode(textEl.Content);
        return new MarkupString($"<text {attrString}>{content}</text>");
    }
}
